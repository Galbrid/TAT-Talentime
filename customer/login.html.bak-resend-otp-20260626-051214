        <p class="footer-title">Links</p>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact Us</a>
      </div>
      <div>
        <p class="footer-title">Address</p>
        <p>No 1 Tolgate, Trichy-621216</p>
      </div>
    </div>
    <p class="footer-note">© 2026 Talentime Business Solutions. All rights reserved.</p>
  </footer>
</body>
</html>
